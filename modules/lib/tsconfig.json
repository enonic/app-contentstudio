{
    "compilerOptions": {
        "module": "ES2022",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": false,
        "lib": [
            "ES2023",
            "DOM"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "preact",
        "outDir": "build/resources/main/dev/lib-contentstudio/",
        "rootDir": "./src/main/resources/assets/js",
        "declaration": true,
        "declarationDir": "build/resources/main/dev/lib-contentstudio/",
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "useDefineForClassFields": false,
        "allowJs": false,
        "noImplicitReturns": false,
        "noImplicitThis": true,
        "strictNullChecks": false,
        "skipLibCheck": true,
        "types": [
            "ckeditor",
            "hasher",
            "jquery",
            "jqueryui"
        ],
        "paths": {
            "react": ["./node_modules/preact/compat"],
            "react-dom": ["./node_modules/preact/compat"],
            "@enonic/lib-admin-ui": ["./.xp/dev/lib-admin-ui/"],
            "*": ["./*"]
        }
    },
    "include": [
        "./src/main/resources/assets/js/page-editor-types.d.ts",
        "./src/main/resources/assets/js/types.d.ts",
        "./src/main/resources/assets/js/**/*"
    ],
    "exclude": [
        "build/**/*",
        "out/**/*"
    ],
    "compileOnSave": false,
    "buildOnSave": false
}
