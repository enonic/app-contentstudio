{
  "name": "@enonic/lib-contentstudio",
  "version": "6.0.0",
  "description": "Enonic XP - Content Studio Library",
  "license": "Enonic License 2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/enonic/app-contentstudio"
  },
  "scripts": {
    "build:prod": "pnpm run /^build:prod:.*$/",
    "build:prod:client": "tsc --pretty",
    "build:prod:lib": "rspack build",
    "build:prod:css": "vite build --mode production --config vite.config.css.mjs",
    "build:dev": "pnpm run /^build:dev:.*$/",
    "build:dev:client": "tsc --pretty --inlineSourceMap --inlineSources",
    "build:dev:lib": "rspack build",
    "build:dev:css": "vite build --mode development --config vite.config.css.mjs",
    "check": "pnpm run /^check:.*$/",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs src/main/resources/assets/js/v6",
    "check:types": "tsc --skipLibCheck --declaration --noEmit",
    "check:lint": "oxlint -c ../../.oxlintrc.json --quiet src/main/resources/assets/js",
    "check:lint:fix": "oxlint -c ../../.oxlintrc.json --quiet --fix src/main/resources/assets/js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@enonic/page-editor": "2.0.0-beta.1",
    "@enonic/ui": "^1.0.5",
    "@nanostores/preact": "^1.0.0",
    "ckeditor4-react": "4.3.0",
    "class-variance-authority": "^0.7.1",
    "d3": "^7.9.0",
    "d3-dag": "^0.11.5",
    "dompurify": "^3.3.0",
    "enonic-admin-artifacts": "^2.4.0",
    "flag-icons": "^7.5.0",
    "hasher": "^1.2.0",
    "jquery-simulate": "^1.0.2",
    "jquery-ui": "^1.14.1",
    "jsondiffpatch": "^0.7.3",
    "lucide-react": "^0.577.0",
    "nanoid": "~5.1.5",
    "nanostores": "^0.11.4",
    "neverthrow": "^8.2.0",
    "preact": "^10.29.0",
    "q": "^1.5.1",
    "react-virtuoso": "^4.18.1",
    "sortablejs": "^1.15.6",
    "tw-animate-css": "^1.3.8"
  },
  "peerDependencies": {
    "@enonic/lib-admin-ui": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "focus-trap-react": "^11.0.0"
  },
  "devDependencies": {
    "@enonic/lib-admin-ui": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.2",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.3.1",
    "@types/ckeditor": "^4.9.10",
    "@types/core-js": "^2.5.8",
    "@types/hasher": "0.0.35",
    "@types/jquery": "^3.5.33",
    "@types/jqueryui": "^1.12.24",
    "@types/q": "^1.5.8",
    "@types/sortablejs": "^1.15.9",
    "@vitest/ui": "^4.1.9",
    "css-loader": "^7.1.2",
    "dependency-cruiser": "^18.0.0",
    "focus-trap-react": "^11.0.0",
    "happy-dom": "^20.8.8",
    "jquery": "^3.7.1",
    "less-loader": "^12.3.0",
    "minimist": "^1.2.8",
    "oxlint": "1.71.0",
    "tailwindcss": "^4.1.13",
    "typescript": "7.0.1-rc",
    "vite": "^7.1.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">= 24.16.0",
    "pnpm": ">= 10.33.4"
  }
}
